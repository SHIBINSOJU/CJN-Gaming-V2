<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="<%= botName %> — <%= botDescription %>" />
  <title><%= botName %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>

  <!-- ── Animated background particles ── -->
  <div class="bg-particles" aria-hidden="true">
    <span></span><span></span><span></span><span></span>
    <span></span><span></span><span></span>
  </div>

  <!-- ── Header / Nav ── -->
  <header class="site-header">
    <nav class="nav container">
      <div class="nav-brand">
        <div class="nav-avatar-wrap">
          <img
            src="https://cdn.discordapp.com/embed/avatars/0.png"
            alt="<%= botName %> avatar"
            class="nav-avatar"
            id="navAvatar"
            onerror="this.src='https://cdn.discordapp.com/embed/avatars/0.png'"
          />
        </div>
        <span class="nav-name"><%= botName %></span>
      </div>
      <div class="nav-status">
        <span class="status-dot" aria-label="Online"></span>
        <span class="status-label">Online</span>
      </div>
    </nav>
  </header>

  <!-- ── Hero ── -->
  <main>
    <section class="hero container">
      <div class="hero-glow" aria-hidden="true"></div>

      <div class="hero-avatar-wrap">
        <div class="avatar-ring">
          <img
            src="https://cdn.discordapp.com/embed/avatars/0.png"
            alt="<%= botName %> avatar"
            class="hero-avatar"
            id="heroAvatar"
            onerror="this.src='https://cdn.discordapp.com/embed/avatars/0.png'"
          />
        </div>
        <div class="online-badge" aria-label="Active"></div>
      </div>

      <h1 class="hero-title"><%= botName %></h1>

      <p class="hero-desc"><%= botDescription %></p>

      <!-- Stats row -->
      <div class="stats-row" role="list">
        <div class="stat-card" role="listitem">
          <span class="stat-icon" aria-hidden="true">🏰</span>
          <span class="stat-value" id="serverCount"><%= serverCount %></span>
          <span class="stat-label">Servers</span>
        </div>
        <div class="stat-card" role="listitem">
          <span class="stat-icon" aria-hidden="true">⚡</span>
          <span class="stat-value">Live</span>
          <span class="stat-label">MC Status</span>
        </div>
        <div class="stat-card" role="listitem">
          <span class="stat-icon" aria-hidden="true">🛡️</span>
          <span class="stat-value">24 / 7</span>
          <span class="stat-label">Uptime</span>
        </div>
      </div>

      <!-- CTA Buttons -->
      <div class="cta-row">
        <a
          href="<%= inviteUrl %>"
          id="inviteBtn"
          class="btn btn-primary"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg class="btn-icon" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path d="M10 1a9 9 0 100 18A9 9 0 0010 1zm4.293 6.293a1 1 0 010 1.414L10.414 12.586a1 1 0 01-1.414 0L6.707 10.293a1 1 0 011.414-1.414L9 10.672V6a1 1 0 012 0v4.672l1.879-1.793a1 1 0 011.414 0z"/>
          </svg>
          Add to Discord
        </a>
        <a
          href="<%= supportUrl %>"
          id="supportBtn"
          class="btn btn-secondary"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg class="btn-icon" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M18 10c0 3.866-3.582 7-8 7a8.841 8.841 0 01-4.083-.98L2 17l1.338-3.123C2.493 12.767 2 11.434 2 10c0-3.866 3.582-7 8-7s8 3.134 8 7zM7 9H5v2h2V9zm8 0h-2v2h2V9zM9 9h2v2H9V9z" clip-rule="evenodd"/>
          </svg>
          Support Server
        </a>
      </div>
    </section>

    <!-- ── Feature cards ── -->
    <section class="features container" aria-label="Features">
      <div class="feature-card">
        <div class="feature-icon" aria-hidden="true">🎮</div>
        <h2 class="feature-title">Live MC Status</h2>
        <p class="feature-desc">Real-time Minecraft server status, player count, and ping — updated every 30 seconds.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon" aria-hidden="true">📊</div>
        <h2 class="feature-title">Slash Commands</h2>
        <p class="feature-desc">Clean, modern Discord slash commands for instant server info without clutter.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon" aria-hidden="true">🔔</div>
        <h2 class="feature-title">Auto Updates</h2>
        <p class="feature-desc">Status embeds auto-refresh so your community always sees the latest server info.</p>
      </div>
    </section>
  </main>

  <!-- ── Footer ── -->
  <footer class="site-footer">
    <p class="footer-text">
      &copy; <%= new Date().getFullYear() %> <%= botName %> &mdash; Built with ❤️ for the CJN Gaming community
    </p>
  </footer>

</body>
</html>
