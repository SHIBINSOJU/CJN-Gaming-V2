# ─── Discord ───────────────────────────────────────────────
DISCORD_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_client_id_here

# ─── MongoDB ────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/cjn-mc-bot

# ─── Bot Config ─────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
DEFAULT_REFRESH_INTERVAL=30000
REFRESH_COOLDOWN=10000
